PORT=3000
APP_BASE_URL=http://localhost:3000

# Required for real HubSpot OAuth. The demo works without these by using mock mode.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/auth/hubspot/callback

# Optional: set to "real" when HubSpot credentials are configured.
HUBSPOT_MODE=mock

# Protects webhook-style sync routes. Change this in any deployed environment.
WEBHOOK_API_KEY=dev-webhook-secret
